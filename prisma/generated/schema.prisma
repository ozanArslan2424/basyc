model Attachment {
  id        Int            @id @default(autoincrement())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  type      AttachmentType
  url       String
  size      Float

  createdById Int
  createdBy   Person @relation("attachment_created_by", fields: [createdById], references: [id])
  thingId     Int
  thing       Thing  @relation("thing_attachments", fields: [thingId], references: [id])
}

enum AttachmentType {
  image
  document
  other
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  name          String
  email         String
  emailVerified Boolean @default(false)
  image         String?
  password      String

  sessions Session[]
  profile  Person?   @relation("user_person")

  @@unique([email])
  @@map("user")
}

model Session {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@map("session")
}

model Verification {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  variant   String
  value     String
  expiresAt DateTime

  @@map("verification")
}

model Comment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content String

  createdBy   Person @relation("comment_created_by", fields: [createdById], references: [id])
  createdById Int

  @@map("comment")
}

model Person {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  email String
  image String?
  role  PersonRole @default(user)

  assignedThings     Thing[]      @relation("thing_assigned_to")
  createdThings      Thing[]      @relation("thing_created_by")
  createdComments    Comment[]    @relation("comment_created_by")
  createdAttachments Attachment[] @relation("attachment_created_by")

  userId String @unique
  user   User   @relation("user_person", fields: [userId], references: [id])

  @@map("profile")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

generator zod {
  provider              = "prisma-zod-generator"
  output                = "../generated/zod"
  config                = "../prisma/zod-generator.config.json"
  optionalFieldBehavior = "nullable"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Priority {
  low
  medium
  high
  extreme
}

enum PersonRole {
  super_admin
  admin
  user
}

model Thing {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content String

  attachments Attachment[] @relation("thing_attachments")

  assignedToId Int?
  assignedTo   Person? @relation("thing_assigned_to", fields: [assignedToId], references: [id])

  createdById Int
  createdBy   Person @relation("thing_created_by", fields: [createdById], references: [id])

  @@map("thing")
}
