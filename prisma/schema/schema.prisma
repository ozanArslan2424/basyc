generator client {
    provider = "prisma-client-js"
    output   = "../generated"
}

generator zod {
    provider              = "prisma-zod-generator"
    output                = "../generated/zod"
    config                = "../prisma/zod-generator.config.json"
    optionalFieldBehavior = "nullable"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

enum Priority {
    low
    medium
    high
    extreme
}

enum PersonRole {
    super_admin
    admin
    user
}
