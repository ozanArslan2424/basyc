{
	"name": "basyc",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot index.ts",
		"build": "bun build --compile --target bun --outfile server index.ts",
		"fm": "prettier --write .",
		"lint": "bunx oxlint --type-aware",
		"db:mig": "bunx --bun prisma migrate dev --create-only",
		"db:push": "bunx --bun prisma migrate deploy",
		"db:gen": "bunx --bun prisma generate",
		"db:studio": "bunx --bun prisma studio",
		"db:seed": "bunx --bun prisma db seed",
		"db:reset": "bunx --bun prisma migrate reset"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.0",
		"@elysiajs/eden": "^1.4.4",
		"@elysiajs/openapi": "^1.4.11",
		"@elysiajs/static": "^1.4.6",
		"elysia": "^1.4.15",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"bun-plugin-tailwind": "^0.1.2",
		"oxlint": "^1.26.0",
		"oxlint-tsgolint": "^0.3.0",
		"prettier": "^3.6.2",
		"prisma": "^6.19.0",
		"prisma-zod-generator": "^1.31.7"
	}
}
